{
  "name": "calibre-tour-assignment",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --dir backend dev\" \"pnpm --dir frontend dev\"",
    "dev:backend": "pnpm --dir backend dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "build": "pnpm --dir backend exec tsc --noEmit && pnpm --dir frontend build",
    "seed": "pnpm --dir backend seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}